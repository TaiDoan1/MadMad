# Copy file này thành ".env" trong cùng thư mục rồi điền giá trị thật.
# Không commit file .env thật lên Git (đã được .gitignore chặn).

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Server ---
PORT=5000

# --- Admin login (trang /admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Dùng 1 trong 2 khoá dưới để ký JWT cho phiên đăng nhập admin
ADMIN_JWT_SECRET=change-me-random-string
ADMIN_SECRET_KEY=change-me-random-string

# --- Marketing page (trang khuyến mãi riêng) ---
MARKETING_ADMIN_PASSWORD=change-me

# --- Cloudinary (lưu trữ & tối ưu ảnh) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP Gmail (gửi email xác nhận đơn hàng) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
