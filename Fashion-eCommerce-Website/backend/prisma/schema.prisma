datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 🛍️ Bảng Sản phẩm (Product)
model Product {
  id           String   @id @default(uuid())
  name         String
  sku          String   @unique
  price        Int
  image        String
  category     String
  sizeGuideProfile String?  // Khóa bảng gợi ý size (kiểu/form) — tham chiếu StorefrontSetting.sizeGuideJson.byProfile
  sizeGuideOverrideJson String?  // Bảng gợi ý size riêng cho từng SP (JSON)
  sizeChartImage String?  // URL hình ảnh bảng size (size chart) cho sản phẩm
  description  String?
  sizes        String   // Lưu danh sách size ngăn cách bởi dấu phẩy, ví dụ: "S,M,L,XL"
  colors       String   // Lưu danh sách màu ngăn cách bởi dấu phẩy, ví dụ: "Black,White,Grey"
  colorImages  String?  // Lưu JSON chuỗi mapping màu sắc sang ảnh
  images       String?  // Lưu JSON mảng danh sách URL ảnh bộ sưu tập
  originalPrice       Int?
  discountPercent     Int?
  showDiscountPercent Boolean  @default(false)
  isPreOrder   Boolean  @default(false)
  preOrderDays Int?
  isGiftProduct Boolean @default(false)
  giftConditionsJson String?
  isFeatured   Boolean  @default(false)
  orderIndex   Int      @default(0) // Lưu thứ tự sắp xếp sản phẩm kéo thả
  stock        Int?     @default(999)
  variantStock String?  @default("{}")
  receivedStock Int?
  receivedVariantStock String? @default("{}")
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 📦 Bảng Đơn hàng (Order)
model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  street         String
  ward           String
  district       String
  province       String
  subtotal       Int
  discount       Int
  shipping       Int
  total          Int
  paymentMethod  String
  shippingMethod String
  status         String      @default("pending") // pending, processing, shipping, completed, cancelled
  isPaid         Boolean     @default(false)
  containsPreOrder Boolean   @default(false)
  isEdited       Boolean     @default(false)
  editedAt       DateTime?
  notes          String?
  internalNote   String?
  couponCode     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
}

// 🛒 Bảng Chi tiết Đơn hàng (OrderItem)
model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  productImage String
  isPreOrder   Boolean  @default(false)
  preOrderDays Int?
  preOrderFulfilledAt DateTime?
  quantity     Int
  size         String
  color        String
  price        Int
  editMetaJson String?
}

// 👑 Bảng Thành viên VIP (VIPMember)
model VIPMember {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String?  @unique
  email     String   @unique
  googleId  String?  @unique
  avatarUrl String?
  points    Int      @default(0)
  tier      String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ⚙️ Bảng Cấu hình Storefront (StorefrontSetting)
model StorefrontSetting {
  id                       Int     @id @default(1)
  brandName                String  @default("MADMAD STUDIO")
  logoUrl                  String?
  manifestoSlogan          String?
  facebookUrl              String?
  instagramUrl             String?
  tiktokUrl                String?
  shopeeUrl                String?
  instagramImages          String? // Lưu mảng các ảnh dạng JSON String

  // 🖼️ Ảnh & nội dung Banner trang chủ (Hero) + Danh mục phổ biến + Best seller
  heroImage                String?
  heroImagesJson           String? @default("[]")
  heroImageScalePercent    Int?    @default(100)
  heroSlideIntervalMs      Int?    @default(6000)
  heroBadgeText            String?
  heroTitleLine1           String?
  heroTitleLine2           String?
  heroDescription          String?
  heroButtonText           String?
  heroOverlayOpacityLeft   Int?    @default(60)
  heroOverlayOpacityMiddle Int?    @default(40)
  heroOverlayOpacityRight  Int?    @default(60)
  heroContentAlign         String? @default("center")
  heroFontStyle            String? @default("default")
  popularCategoryImagesJson      String? @default("[]")
  topBannerImagesJson            String? @default("[]")
  bestSellerProductIdsJson       String? @default("[]")
  bestSellerImageOverridesJson   String? @default("{}")
  colorHexMapJson                String? @default("{}")

  printInvoiceTitle        String?
  printInvoiceAddress      String?
  printInvoicePhone        String?
  printInvoiceFooterSlogan String?
  printInvoicePolicy       String?

  // Coupons/vouchers lưu dạng JSON String (để storefront sync)
  couponsJson              String? @default("[]")

  // Product options (categories, sizes, colors, tags) cho admin quản lý sản phẩm
  productOptionsJson       String? @default("{}")

  // Membership tier configs (quy tắc thăng hạng/ưu đãi) lưu JSON
  membershipTiersJson      String? @default("[]")

  // Bảng gợi ý size theo chiều cao/cân nặng (mặc định + theo danh mục)
  sizeGuideJson            String? @default("{}")
  
  // Các trường cấu hình email, SĐT, địa chỉ cửa hàng đồng bộ Cloud
  storeEmail               String? @default("mmadmadstudio@gmail.com")
  storePhone               String? @default("+84 123 456 789")
  storeAddress             String? @default("123 Fashion Street, Ho Chi Minh City")

  // Cấu hình nội dung email gửi cho khách hàng tự chỉnh sửa
  customerEmailSubject     String? @default("[{{brandName}}] ĐẶT HÀNG THÀNH CÔNG - ĐƠN HÀNG {{orderNumber}}")
  customerEmailTemplate    String? @default("Chào bạn <strong>{{customerName}}</strong>,<br><br>Cám ơn bạn đã lựa chọn nổi loạn và khẳng định cá tính cùng <strong>{{brandName}}</strong>. Chúng tôi xác nhận đã nhận được đơn hàng của bạn và đang tiến hành đóng gói siêu tốc!")

  // Cấu hình SMTP Gmail động điều khiển từ Admin
  smtpHost                 String? @default("smtp.gmail.com")
  smtpPort                 Int?    @default(587)
  smtpUser                 String? @default("mmadmadstudio@gmail.com")
  smtpPass                 String? @default("yxmbctjhsxkyeznx")
  smtpSenderName           String? @default("MADMAD STUDIO")

  // 💳 Cổng Thanh Toán & Vận Chuyển
  bankId                   String? @default("MB")
  bankAccount              String? @default("0999999999")
  bankAccountName          String? @default("MADMAD STUDIO")
  momoPhone                String? @default("0999999999")
  momoAccountName          String? @default("MADMAD STUDIO")
  enableCod                Boolean @default(true)
  enableBank               Boolean @default(true)
  enableMomo               Boolean @default(true)
  enablePaypal             Boolean @default(false)
  shippingFeeStandard      Int?    @default(30000)
  shippingFeeExpress       Int?    @default(60000)
  shippingFreeThreshold    Int?    @default(500000)
  shippingExpressCities    String? @default("79,01")
  orderAutoCancelHours     Int?    @default(24)

  // 🌐 Cấu hình Tiền tệ Quốc tế
  currencyMode             String? @default("auto")
  exchangeRate             Int?    @default(25000)
  intlConversionFeePercent Float?  @default(3.5)
  intlShippingFee          Int?    @default(250000)
  intlMarkupPercent        Float?  @default(10)

  // 🖨️ Hóa đơn in thêm
  printInvoiceSubheader    String? @default("Tối giản . Độc bản . Cao cấp")
  printInvoiceBankId       String? @default("MB")
  printInvoiceBankAccount  String? @default("0999999999")
  printInvoiceAccountName  String? @default("MADMAD STUDIO")

  // 🏪 Thông tin cửa hàng bổ sung
  storeName                String? @default("MADMAD Studio")
}

// 🎁 Bảng Tặng KOL/KOC (Marketing Gift)
model MarketingGift {
  id           String              @id @default(uuid())
  giftNumber   String              @unique
  kolName      String
  kolHandle    String?
  platform     String?
  contactInfo  String?
  cashAmount   Int                 @default(0)
  productValue Int                 @default(0)
  totalCost    Int                 @default(0)
  notes        String?
  status       String              @default("completed")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        MarketingGiftItem[]
}

model MarketingGiftItem {
  id           String        @id @default(uuid())
  giftId       String
  gift         MarketingGift @relation(fields: [giftId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  productImage String?
  color        String
  size         String
  quantity     Int
  unitPrice    Int
  lineTotal    Int
}

// 📒 Nhật ký biến động tồn kho (hoàn đơn, trả hàng, đơn hàng, marketing...)
model StockMovement {
  id             String   @id @default(uuid())
  productId      String
  productName    String
  color          String
  size           String
  quantityDelta  Int
  reason         String
  referenceType  String?
  referenceId    String?
  referenceLabel String?
  stockBefore    Int?
  stockAfter     Int?
  notes          String?
  createdAt      DateTime @default(now())
}

// 🚨 Bảng Nhật ký Lỗi Hệ Thống (SystemLog)
model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String   @default("info") // critical, error, warning, info, success
  source    String   @default("backend") // frontend, backend
  message   String
  details   String?  // JSON string chứa stack trace, context...
  url       String?  // Trang bị lỗi
  userAgent String?  // Thiết bị của khách
  ip        String?  // IP người dùng
  duration  Int?     // Thời gian xử lý (ms) - dùng cho log performance
  createdAt DateTime @default(now())
}
